PROJECT_NAME=fundacion-te-apoyamos

# RabbitMQ - DOCKER (servicio rabbitmq)
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_ENDPOINT=http://localhost:15672/api

# MySQL - DOCKER (servicio mysql)
MYSQL_HOSTNAME=mysql
MYSQL_PORT=3306
MYSQL_USER=appuser
MYSQL_PASSWORD=appuser_password_dev
MYSQL_ROOT_PASSWORD=root_password_dev
MYSQL_DATABASE=fundacion_te_apoyamos_db

# Desarrollo local
NODE_ENV=development
PORT=3000

# JWT y Criptografía (para queue)
# Genera una key de 64 caracteres hexadecimales: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=mi_jwt_secret_super_seguro_cambiar_en_produccion
KEY_CRYPTO=2cefbac12a6dbbaf491ec54081280d68ede4b7b4d208909ad93b34bc3e1e45a4
IV_CRYPTO=c7ebe3b4de5967f5df3328c1ec12b37b

# HubSpot - Obtener desde tu cuenta de HubSpot
# 1. Private App Token: Settings > Integrations > Private Apps > Create token
#    Scopes necesarios:
#    - crm.objects.contacts.read, crm.objects.contacts.write
#    - crm.objects.companies.read, crm.objects.companies.write
#    - crm.schemas.contacts.read, crm.schemas.contacts.write
#    - crm.schemas.companies.read, crm.schemas.companies.write
HUBSPOT_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 2. Client Secret: Settings > Integrations > Private Apps > Show secret
#    Usado para validar webhooks con HMAC-SHA256
HUBSPOT_CLIENT_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
