# FQDN inths.fundacionteapoyamos.cl (debe coincidir con el certificado Let's Encrypt).
#
# --- Flujo recomendado (opción A): autofirmado → nginx → Let’s Encrypt ---
#
# 1) En el servidor, desde la raíz del repo:
#      sudo ./scripts/setup-ssl-path-a.sh
#    (crea /var/www/certbot, /etc/nginx/ssl y un fullchain.pem/privkey.pem temporal)
#
# 2) Enlazar o copiar este fichero a sites-enabled, luego:
#      sudo nginx -t && sudo systemctl reload nginx
#
# 3) Levantar certbot (emite LE y sustituye los PEM en /etc/nginx/ssl/):
#      docker compose -f docker-compose-certbot.yml up -d
#
# Alternativa sin HTTPS hasta tener LE: nginx/queue_app.phase1-http-only
#
# Certificados LE finales: copiados a /etc/nginx/ssl/ por el entrypoint/scripts certbot.

# --- HTTP: validación ACME + redirección a HTTPS ---
server {
    listen 80;
    server_name inths.fundacionteapoyamos.cl;

    # ^~ evita que otras locations (regex, proxy) roben la petición
    location ^~ /.well-known/acme-challenge/ {
        root /var/www/certbot;
        default_type "text/plain";
        allow all;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# --- HTTPS: aplicación ---
server {
    listen 443 ssl http2;
    server_name inths.fundacionteapoyamos.cl;

    ssl_certificate     /etc/nginx/ssl/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    # Si Let's Encrypt sigue la redirección 301 HTTP→HTTPS, el desafío debe
    # servirse aquí desde el mismo webroot (no desde el proxy al SSR).
    location ^~ /.well-known/acme-challenge/ {
        root /var/www/certbot;
        default_type "text/plain";
        allow all;
    }

    # -------------------------
    # Frontend
    # -------------------------
    location / {
        proxy_pass http://127.0.0.1:9010;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    # -------------------------
    # Core API (Backend)
    # -------------------------
  #  location /api/ {
  #      proxy_pass http://10.0.2.5:3001/;
  #      proxy_http_version 1.1;
  #      proxy_set_header Host $host;
  #      proxy_set_header X-Real-IP $remote_addr;
  #      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
  #      proxy_set_header X-Forwarded-Proto $scheme;
  #      proxy_set_header Connection "";
  #  }

    # -------------------------
    # RabbitMQ Management UI
    # -------------------------
    location /rabbit/ {
        proxy_pass http://10.0.2.5:15672/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Manejo básico de errores
    error_page 502 /502.html;
    location = /502.html {
        root /usr/share/nginx/html;
        internal;
    }
}
