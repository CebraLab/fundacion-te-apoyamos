# HubSpot API Credentials
# Obtener desde: Settings > Integrations > Private Apps

# Private App Token (PAT) - Token de autenticación
# Scopes requeridos:
# - crm.objects.contacts.read
# - crm.objects.contacts.write  
# - crm.objects.companies.read
# - crm.objects.companies.write
# - crm.schemas.contacts.read
# - crm.schemas.contacts.write
# - crm.schemas.companies.read
# - crm.schemas.companies.write
HUBSPOT_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Client Secret - Para validación de webhooks
# Usado para verificar la firma HMAC-SHA256 de los webhooks
HUBSPOT_CLIENT_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# RabbitMQ Configuration
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
